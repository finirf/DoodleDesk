# Supabase Frontend Configuration
# These are PUBLIC values (safe to commit)
# The anon key is designed to be used in browsers; security is enforced by RLS policies

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
VITE_ENABLE_FINAL_PROJECT=true

# Supabase Backend Configuration (for Edge Functions)
# These are SECRET values - NEVER commit to git
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Email Service Configuration
RESEND_API_KEY=your_resend_api_key_here
FRIEND_REQUEST_FROM_EMAIL=noreply@yourdomain.com
FRIEND_REQUEST_WEBHOOK_SECRET=your_webhook_secret_here

# Application Configuration
APP_BASE_URL=https://your-app-domain.com
ALLOWED_ORIGINS=https://your-app-domain.com
